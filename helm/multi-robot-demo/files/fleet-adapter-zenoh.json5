{
  // Zenoh config for free_fleet_adapter — connects to the dedicated zenoh-router
  // pod. Multicast is disabled (blocked by OVN-Kubernetes CNI on OpenShift).
  mode: "client",
  connect: {
    endpoints: ["tcp/zenoh-router:7447"],
    retry: {
      period_init_ms: 1000,
      period_max_ms: 16000,
      period_increase_factor: 2
    },
    exit_on_failure: false
  },
  scouting: {
    multicast: {
      enabled: false
    }
  }
}
