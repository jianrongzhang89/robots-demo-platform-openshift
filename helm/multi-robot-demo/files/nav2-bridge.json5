{
  plugins: {
    ros2dds: {
      // Expanded allowlist for Open-RMF free_fleet integration.
      // In addition to sensor/cmd_vel traffic to/from Gazebo, the bridge
      // now exposes TF (robot pose for free_fleet_adapter) and the
      // NavigateToPose action (so free_fleet_adapter can send goals).
      allow: {
        // Outbound (robot → RMF): pose and battery state
        publishers: [
          ".*/(tf|tf_static|battery_state)"
        ],
        // Inbound (RMF → robot): navigation goals via Nav2 action
        subscribers: [
          ".*/navigate_to_pose/_action/.*"
        ],
        service_servers: [
          ".*/navigate_to_pose/_action/.*"
        ]
      }
    }
  },

  // Client mode: connect to the dedicated zenoh-router pod.
  // Nav2 pods survive Gazebo restarts because the router is independent.
  mode: "client",

  connect: {
    endpoints: [
      "tcp/zenoh-router:7447"
    ],
    retry: {
      period_init_ms: 1000,
      period_max_ms: 16000,
      period_increase_factor: 2
    },
    exit_on_failure: false
  },

  scouting: {
    multicast: {
      enabled: false
    }
  }
}
