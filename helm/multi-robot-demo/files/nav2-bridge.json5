{
  plugins: {
    ros2dds: {
      // No namespace prefix — Nav2 already runs under /robot_N/ namespace,
      // so all its local DDS topics are already correctly prefixed.
    }
  },

  // Client mode: connect to the dedicated zenoh-router pod.
  // Nav2 pods survive Gazebo restarts because the router is independent.
  mode: "client",

  connect: {
    endpoints: [
      "tcp/zenoh-router:7447"
    ],
    retry: {
      period_init_ms: 1000,
      period_max_ms: 16000,
      period_increase_factor: 2
    },
    exit_on_failure: false
  },

  scouting: {
    multicast: {
      enabled: false
    }
  }
}
